# ============================================================
# READSX — Environment Variables
# Copy this to .env.local and fill in your keys
# ============================================================

# ── Gemini AI (Required) ──────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Session Encryption ────────────────────────────────────────
# A strong random string for AES-256 session encryption
SESSION_ENCRYPTION_KEY=your-super-secret-key-change-this-immediately

# ── News API (Optional) ───────────────────────────────────────
# Get from: https://newsapi.org/register
# Falls back to Hacker News (free) if not set
NEWS_API_KEY=your_newsapi_key_here

# ── Telegram 2FA Webhook (Optional) ──────────────────────────
# For 2FA challenge notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
